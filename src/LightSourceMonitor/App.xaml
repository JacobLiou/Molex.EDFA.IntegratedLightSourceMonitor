<Application x:Class="LightSourceMonitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDark.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Styles -->
            <Style x:Key="MonoValueText" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="#E8E8F0"/>
            </Style>

            <Style x:Key="KpiValueText" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="32"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="#E8E8F0"/>
            </Style>

            <Style x:Key="UnitText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="Foreground" Value="#9898B0"/>
            </Style>

            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#E8E8F0"/>
                <Setter Property="Margin" Value="0,8,0,4"/>
            </Style>

            <!-- Status indicator colors -->
            <SolidColorBrush x:Key="StatusNormalBrush" Color="#00E676"/>
            <SolidColorBrush x:Key="StatusWarningBrush" Color="#FFAB00"/>
            <SolidColorBrush x:Key="StatusCriticalBrush" Color="#FF1744"/>
            <SolidColorBrush x:Key="StatusOfflineBrush" Color="#616161"/>
            <SolidColorBrush x:Key="AccentBlueBrush" Color="#448AFF"/>
            <SolidColorBrush x:Key="AccentPurpleBrush" Color="#7C4DFF"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#23233D"/>
            <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#2D2D4A"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
