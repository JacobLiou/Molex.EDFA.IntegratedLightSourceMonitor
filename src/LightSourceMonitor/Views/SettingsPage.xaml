<UserControl x:Class="LightSourceMonitor.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <TabControl Background="Transparent" BorderThickness="0" Margin="0,0,0,16">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#9898B0"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="#448AFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.ItemContainerStyle>

            <!-- Device Management Tab -->
            <TabItem Header="设备管理">
                <Border Background="#23233D" CornerRadius="8" Padding="20" Margin="0,12,0,0">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <TextBlock Text="设备管理" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="PD阵列和波长计的设备配置将在连接硬件后自动识别" 
                                   Foreground="#9898B0" Margin="0,0,0,16"/>
                        <TextBlock Text="此功能将在硬件驱动层完成后启用" Foreground="#55556A" FontStyle="Italic"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Alarm Thresholds Tab -->
            <TabItem Header="告警阈值">
                <Border Background="#23233D" CornerRadius="8" Padding="20" Margin="0,12,0,0">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <TextBlock Text="告警阈值配置" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="PD功率报警阈值 (dB):" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <hc:NumericUpDown Grid.Column="1" Value="{Binding PdAlarmDelta}" Minimum="0.01" 
                                              Maximum="10" Increment="0.01" Width="150" HorizontalAlignment="Left"
                                              Style="{StaticResource NumericUpDownExtend}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Text="WM波长报警阈值 (nm):" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <hc:NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding WmAlarmDelta}" Minimum="0.001"
                                              Maximum="1" Increment="0.001" Width="150" HorizontalAlignment="Left"
                                              Style="{StaticResource NumericUpDownExtend}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Email Tab -->
            <TabItem Header="邮件通知">
                <Border Background="#23233D" CornerRadius="8" Padding="20" Margin="0,12,0,0">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <TextBlock Text="SMTP 邮件配置" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="SMTP 服务器:" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding SmtpServer}" 
                                     hc:InfoElement.Placeholder="smtp.example.com"
                                     Style="{StaticResource TextBoxExtend}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Text="端口:" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <hc:NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding SmtpPort}"
                                              Minimum="1" Maximum="65535" Width="120" HorizontalAlignment="Left"
                                              Style="{StaticResource NumericUpDownExtend}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Text="用户名:" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SmtpUsername}"
                                     Style="{StaticResource TextBoxExtend}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="3" Text="密码:" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <PasswordBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="4" Text="发件人:" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding FromAddress}"
                                     hc:InfoElement.Placeholder="monitor@example.com"
                                     Style="{StaticResource TextBoxExtend}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="5" Text="收件人:" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Recipients}"
                                     hc:InfoElement.Placeholder="user1@example.com; user2@example.com"
                                     Style="{StaticResource TextBoxExtend}" Margin="0,0,0,8"/>
                        </Grid>
                        <Button Content="发送测试邮件" Command="{Binding TestSmtpCommand}" Margin="0,12,0,0"
                                Style="{StaticResource ButtonPrimary}" HorizontalAlignment="Left" Padding="16,6"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- TMS Tab -->
            <TabItem Header="TMS 对接">
                <Border Background="#23233D" CornerRadius="8" Padding="20" Margin="0,12,0,0">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <TextBlock Text="TMS 系统对接配置" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="API 地址:" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding TmsBaseUrl}"
                                     hc:InfoElement.Placeholder="https://tms.example.com/api"
                                     Style="{StaticResource TextBoxExtend}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Text="API Key:" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TmsApiKey}"
                                     Style="{StaticResource TextBoxExtend}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Text="上传间隔(s):" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <hc:NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding TmsUploadIntervalSec}"
                                              Minimum="10" Maximum="3600" Width="150" HorizontalAlignment="Left"
                                              Style="{StaticResource NumericUpDownExtend}"/>
                        </Grid>
                        <Button Content="测试连接" Command="{Binding TestTmsConnectionCommand}" Margin="0,12,0,0"
                                Style="{StaticResource ButtonPrimary}" HorizontalAlignment="Left" Padding="16,6"/>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>
    </ScrollViewer>
</UserControl>
