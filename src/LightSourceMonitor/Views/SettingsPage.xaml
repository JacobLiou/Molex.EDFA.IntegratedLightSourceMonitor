<UserControl x:Class="LightSourceMonitor.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <TabControl Background="Transparent" BorderThickness="0" Margin="0,0,0,16">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#9898B0"/>
                    <Setter Property="Padding" Value="20,10"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="#448AFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.ItemContainerStyle>

            <!-- Device Management Tab -->
            <TabItem Header="设备管理">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,12,0,0">
                        <!-- Driver Status -->
                        <Border Background="#23233D" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="驱动状态" Style="{StaticResource SectionHeader}"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="运行模式:" Foreground="#9898B0" VerticalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DriverMode}" Foreground="#7C4DFF" FontWeight="SemiBold" Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="1" Text="PD阵列驱动:" Foreground="#9898B0" VerticalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PdDriverStatus}" Foreground="#00E676" Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="2" Text="波长计驱动:" Foreground="#9898B0" VerticalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WmDriverStatus}" Foreground="#00E676" Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="3" Text="数据采集:" Foreground="#9898B0" VerticalAlignment="Center" Margin="0,0,0,6"/>
                                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                                        <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#616161"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAcquisitionRunning}" Value="True">
                                                            <Setter Property="Fill" Value="#00E676"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Foreground="#E8E8F0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="已停止"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAcquisitionRunning}" Value="True">
                                                            <Setter Property="Text" Value="运行中"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Channel List -->
                        <Border Background="#23233D" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="激光通道配置" Style="{StaticResource SectionHeader}"/>
                                <TextBlock Text="{Binding Channels.Count, StringFormat='共 {0} 个通道'}" Foreground="#9898B0" Margin="0,0,0,12"/>
                                <DataGrid ItemsSource="{Binding Channels}" AutoGenerateColumns="False"
                                          IsReadOnly="True" Background="Transparent" Foreground="#E8E8F0"
                                          BorderThickness="0" GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#334466"
                                          RowBackground="#23233D" AlternatingRowBackground="#1B1B2F"
                                          HeadersVisibility="Column" CanUserResizeRows="False"
                                          MaxHeight="400">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#1B1B2F"/>
                                            <Setter Property="Foreground" Value="#9898B0"/>
                                            <Setter Property="Padding" Value="10,8"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="BorderBrush" Value="#334466"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="设备SN" Binding="{Binding DeviceSN}" Width="120">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="Consolas"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="通道" Binding="{Binding ChannelName}" Width="100"/>
                                        <DataGridTextColumn Header="波长 (nm)" Binding="{Binding SpecWavelength, StringFormat='{}{0:F1}'}" Width="90">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="Consolas"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="功率Min" Binding="{Binding SpecPowerMin, StringFormat='{}{0:F1}'}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="Consolas"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="功率Max" Binding="{Binding SpecPowerMax, StringFormat='{}{0:F1}'}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="Consolas"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="告警Δ" Binding="{Binding AlarmDelta, StringFormat='{}{0:F2}'}" Width="70">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="Consolas"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled}" Width="50"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Acquisition Parameters Tab -->
            <TabItem Header="采集参数">
                <Border Background="#23233D" CornerRadius="8" Padding="20" Margin="0,12,0,0">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <TextBlock Text="数据采集参数" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="调整采集频率和数据存储策略，修改后点击「应用」即时生效" Foreground="#9898B0" Margin="0,0,0,16"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="采集间隔 (ms):" Foreground="#9898B0" VerticalAlignment="Center"/>
                                <TextBlock Text="每次PD功率采集的时间间隔" Foreground="#55556A" FontSize="11"/>
                            </StackPanel>
                            <hc:NumericUpDown Grid.Column="1" Value="{Binding SamplingIntervalMs}" 
                                              Minimum="500" Maximum="60000" Increment="100" Width="160" HorizontalAlignment="Left"
                                              Style="{StaticResource NumericUpDownExtend}" Margin="0,0,0,12"/>

                            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                <TextBlock Text="波长计扫描频率 (每N次):" Foreground="#9898B0" VerticalAlignment="Center"/>
                                <TextBlock Text="每N次PD采集执行一次WM扫描" Foreground="#55556A" FontSize="11"/>
                            </StackPanel>
                            <hc:NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding WmSweepEveryN}" 
                                              Minimum="1" Maximum="1000" Increment="1" Width="160" HorizontalAlignment="Left"
                                              Style="{StaticResource NumericUpDownExtend}" Margin="0,0,0,12"/>

                            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                                <TextBlock Text="数据库写入频率 (每N次):" Foreground="#9898B0" VerticalAlignment="Center"/>
                                <TextBlock Text="每N次采集写入一次数据库" Foreground="#55556A" FontSize="11"/>
                            </StackPanel>
                            <hc:NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding DbWriteEveryN}" 
                                              Minimum="1" Maximum="100" Increment="1" Width="160" HorizontalAlignment="Left"
                                              Style="{StaticResource NumericUpDownExtend}" Margin="0,0,0,12"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="应用采集参数" Command="{Binding ApplyAcquisitionParamsCommand}"
                                    Style="{StaticResource ButtonPrimary}" HorizontalAlignment="Left" Padding="16,6"/>
                            <TextBlock Text="{Binding AcqParamsStatus}" Foreground="#00E676" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Alarm Thresholds Tab -->
            <TabItem Header="告警阈值">
                <Border Background="#23233D" CornerRadius="8" Padding="20" Margin="0,12,0,0">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <TextBlock Text="告警阈值配置" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="PD功率报警阈值 (dB):" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <hc:NumericUpDown Grid.Column="1" Value="{Binding PdAlarmDelta}" Minimum="0.01" 
                                              Maximum="10" Increment="0.01" Width="150" HorizontalAlignment="Left"
                                              Style="{StaticResource NumericUpDownExtend}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Text="WM波长报警阈值 (nm):" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <hc:NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding WmAlarmDelta}" Minimum="0.001"
                                              Maximum="1" Increment="0.001" Width="150" HorizontalAlignment="Left"
                                              Style="{StaticResource NumericUpDownExtend}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Email Tab -->
            <TabItem Header="邮件通知">
                <Border Background="#23233D" CornerRadius="8" Padding="20" Margin="0,12,0,0">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <TextBlock Text="SMTP 邮件配置" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="SMTP 服务器:" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding SmtpServer}" 
                                     hc:InfoElement.Placeholder="smtp.example.com"
                                     Style="{StaticResource TextBoxExtend}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Text="端口:" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <hc:NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding SmtpPort}"
                                              Minimum="1" Maximum="65535" Width="120" HorizontalAlignment="Left"
                                              Style="{StaticResource NumericUpDownExtend}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Text="用户名:" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SmtpUsername}"
                                     Style="{StaticResource TextBoxExtend}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="3" Text="密码:" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <PasswordBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="4" Text="发件人:" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding FromAddress}"
                                     hc:InfoElement.Placeholder="monitor@example.com"
                                     Style="{StaticResource TextBoxExtend}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="5" Text="收件人:" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Recipients}"
                                     hc:InfoElement.Placeholder="user1@example.com; user2@example.com"
                                     Style="{StaticResource TextBoxExtend}" Margin="0,0,0,8"/>
                        </Grid>
                        <Button Content="发送测试邮件" Command="{Binding TestSmtpCommand}" Margin="0,12,0,0"
                                Style="{StaticResource ButtonPrimary}" HorizontalAlignment="Left" Padding="16,6"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- TMS Tab -->
            <TabItem Header="TMS 对接">
                <Border Background="#23233D" CornerRadius="8" Padding="20" Margin="0,12,0,0">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <TextBlock Text="TMS 系统对接配置" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="API 地址:" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding TmsBaseUrl}"
                                     hc:InfoElement.Placeholder="https://tms.example.com/api"
                                     Style="{StaticResource TextBoxExtend}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Text="API Key:" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TmsApiKey}"
                                     Style="{StaticResource TextBoxExtend}" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Text="上传间隔(s):" Foreground="#9898B0" VerticalAlignment="Center"/>
                            <hc:NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding TmsUploadIntervalSec}"
                                              Minimum="10" Maximum="3600" Width="150" HorizontalAlignment="Left"
                                              Style="{StaticResource NumericUpDownExtend}"/>
                        </Grid>
                        <Button Content="测试连接" Command="{Binding TestTmsConnectionCommand}" Margin="0,12,0,0"
                                Style="{StaticResource ButtonPrimary}" HorizontalAlignment="Left" Padding="16,6"/>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>
    </ScrollViewer>
</UserControl>
