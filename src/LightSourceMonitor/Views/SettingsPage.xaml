<UserControl x:Class="LightSourceMonitor.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <TabControl Background="Transparent" BorderThickness="0" Margin="0,0,0,16">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#9898B0"/>
                    <Setter Property="Padding" Value="20,10"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="#448AFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.ItemContainerStyle>

            <!-- Device Management Tab -->
            <TabItem Header="{DynamicResource Settings_Tab_Devices}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Background="#23233D" CornerRadius="8" Padding="14" Margin="0,12,0,0">
                        <StackPanel Margin="0,10,0,0">
                            <Expander Header="{DynamicResource Settings_DriverSection}"
                                      IsExpanded="True"
                                      Foreground="#E8E8F0"
                                      Background="Transparent">
                                <Border Background="#1B1B2F"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,8,0,8">
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{DynamicResource Settings_RunMode}"
                                                   Foreground="#9898B0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DriverMode}"
                                                   Foreground="#7C4DFF"
                                                   FontWeight="SemiBold"
                                                   Margin="10,0,0,6" />
                                        <TextBlock Grid.Row="1"
                                                   Text="{DynamicResource Settings_PdDriver}"
                                                   Foreground="#9898B0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Text="{Binding PdDriverStatus}"
                                                   Foreground="#00E676"
                                                   Margin="10,0,0,6" />
                                        <TextBlock Grid.Row="2"
                                                   Text="{DynamicResource Settings_WbaDriver}"
                                                   Foreground="#9898B0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Text="{Binding WbaDriverStatus}"
                                                   Foreground="#00E676"
                                                   Margin="10,0,0,6" />
                                        <TextBlock Grid.Row="3"
                                                   Text="{DynamicResource Settings_WmDriver}"
                                                   Foreground="#9898B0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Grid.Row="3"
                                                   Grid.Column="1"
                                                   Text="{Binding WmDriverStatus}"
                                                   Foreground="#00E676"
                                                   Margin="10,0,0,6" />
                                        <TextBlock Grid.Row="4"
                                                   Text="{DynamicResource Settings_Acquisition}"
                                                   Foreground="#9898B0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,0,6" />
                                        <StackPanel Grid.Row="4"
                                                    Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    Margin="10,0,0,6">
                                            <Ellipse Width="8"
                                                     Height="8"
                                                     Margin="0,0,6,0"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill"
                                                                Value="#616161" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAcquisitionRunning}"
                                                                         Value="True">
                                                                <Setter Property="Fill"
                                                                        Value="#00E676" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Foreground="#E8E8F0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"
                                                                Value="{DynamicResource Settings_AcqStopped}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAcquisitionRunning}"
                                                                         Value="True">
                                                                <Setter Property="Text"
                                                                        Value="{DynamicResource Settings_AcqRunning}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style></TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Expander>
                            <Expander Header="{DynamicResource Settings_PdChannels}"
                                      IsExpanded="False"
                                      Foreground="#E8E8F0"
                                      Background="Transparent">
                                <Border Background="#1B1B2F"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,8,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding PdChannelsSummary}"
                                                   Foreground="#9898B0"
                                                   Margin="0,0,0,12" />
                                        <Grid MinHeight="220">
                                            <TabControl ItemsSource="{Binding PdDeviceChannelGroups}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Visibility="{Binding PdHasDeviceTabs, Converter={StaticResource BoolToVisibility}}">
                                                <TabControl.ItemContainerStyle>
                                                    <Style TargetType="TabItem">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="Foreground" Value="#9898B0" />
                                                        <Setter Property="Padding" Value="14,8" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Foreground" Value="#448AFF" />
                                                                <Setter Property="Background" Value="#2D2D4A" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TabControl.ItemContainerStyle>
                                                <TabControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding TabHeader}" />
                                                    </DataTemplate>
                                                </TabControl.ItemTemplate>
                                                <TabControl.ContentTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,8,0,0">
                                                            <TextBlock Text="{Binding SnChannelSummary}"
                                                                       Foreground="#9898B0" Margin="0,0,0,8" />
                                                            <DataGrid ItemsSource="{Binding Channels}"
                                                                      AutoGenerateColumns="False"
                                                                      IsReadOnly="True"
                                                                      Background="Transparent"
                                                                      Foreground="#E8E8F0"
                                                                      BorderThickness="0"
                                                                      GridLinesVisibility="Horizontal"
                                                                      HorizontalGridLinesBrush="#334466"
                                                                      RowBackground="#23233D"
                                                                      AlternatingRowBackground="#1B1B2F"
                                                                      HeadersVisibility="Column"
                                                                      CanUserResizeRows="False"
                                                                      MaxHeight="320">
                                                                <DataGrid.ColumnHeaderStyle>
                                                                    <Style TargetType="DataGridColumnHeader">
                                                                        <Setter Property="Background" Value="#1B1B2F" />
                                                                        <Setter Property="Foreground" Value="#9898B0" />
                                                                        <Setter Property="Padding" Value="10,8" />
                                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                                        <Setter Property="BorderBrush" Value="#334466" />
                                                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                                                    </Style>
                                                                </DataGrid.ColumnHeaderStyle>
                                                                <DataGrid.Columns>
                                                                    <DataGridTextColumn Header="{DynamicResource Settings_Grid_Ch}"
                                                                                        Binding="{Binding ChannelName}"
                                                                                        Width="100" />
                                                                    <DataGridTextColumn Header="{DynamicResource Settings_Grid_WlNm}"
                                                                                        Binding="{Binding SpecWavelength, StringFormat='{}{0:F1}'}"
                                                                                        Width="90">
                                                                        <DataGridTextColumn.ElementStyle>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="FontFamily" Value="Consolas" />
                                                                            </Style>
                                                                        </DataGridTextColumn.ElementStyle>
                                                                    </DataGridTextColumn>
                                                                    <DataGridTextColumn Header="{DynamicResource Settings_Grid_PwrMin}"
                                                                                        Binding="{Binding SpecPowerMin, StringFormat='{}{0:F1}'}"
                                                                                        Width="80">
                                                                        <DataGridTextColumn.ElementStyle>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="FontFamily" Value="Consolas" />
                                                                            </Style>
                                                                        </DataGridTextColumn.ElementStyle>
                                                                    </DataGridTextColumn>
                                                                    <DataGridTextColumn Header="{DynamicResource Settings_Grid_PwrMax}"
                                                                                        Binding="{Binding SpecPowerMax, StringFormat='{}{0:F1}'}"
                                                                                        Width="80">
                                                                        <DataGridTextColumn.ElementStyle>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="FontFamily" Value="Consolas" />
                                                                            </Style>
                                                                        </DataGridTextColumn.ElementStyle>
                                                                    </DataGridTextColumn>
                                                                    <DataGridTextColumn Header="{DynamicResource Settings_Grid_AlarmDelta}"
                                                                                        Binding="{Binding AlarmDelta, StringFormat='{}{0:F2}'}"
                                                                                        Width="70">
                                                                        <DataGridTextColumn.ElementStyle>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="FontFamily" Value="Consolas" />
                                                                            </Style>
                                                                        </DataGridTextColumn.ElementStyle>
                                                                    </DataGridTextColumn>
                                                                    <DataGridCheckBoxColumn Header="{DynamicResource Settings_Grid_Enabled}"
                                                                                            Binding="{Binding IsEnabled}"
                                                                                            Width="50" />
                                                                </DataGrid.Columns>
                                                            </DataGrid>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </TabControl.ContentTemplate>
                                            </TabControl>
                                            <TextBlock Text="{DynamicResource Settings_PdEmpty}"
                                                       Foreground="#9898B0"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Visibility="{Binding PdShowEmptyChannelHint, Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Expander>
                            <Expander Header="{DynamicResource Settings_WmSection}"
                                      IsExpanded="False"
                                      Foreground="#E8E8F0"
                                      Background="Transparent">
                                <Border Background="#1B1B2F"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,8,0,8">
                                    <StackPanel Margin="0,4,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="{DynamicResource Settings_WmXmlPath}"
                                                       Foreground="#9898B0"
                                                       Margin="0,0,0,6" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding WmConfigXmlPath}"
                                                       Foreground="#E8E8F0"
                                                       Margin="0,0,0,6"
                                                       FontFamily="Consolas" />
                                            <TextBlock Grid.Row="1"
                                                       Text="{DynamicResource Settings_WmServiceMode}"
                                                       Foreground="#9898B0"
                                                       Margin="0,0,0,6" />
                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="1"
                                                       Text="{Binding WmServiceMode}"
                                                       Foreground="#7C4DFF"
                                                       Margin="0,0,0,6"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Row="2"
                                                       Text="{DynamicResource Settings_WmSimSwitch}"
                                                       Foreground="#9898B0"
                                                       Margin="0,0,0,6" />
                                            <TextBlock Grid.Row="2"
                                                       Grid.Column="1"
                                                       Text="{Binding WmServiceIsSimulated}"
                                                       Foreground="#E8E8F0"
                                                       Margin="0,0,0,6" />
                                            <TextBlock Grid.Row="3"
                                                       Text="{DynamicResource Settings_WmSimCom}"
                                                       Foreground="#9898B0"
                                                       Margin="0,0,0,6" />
                                            <TextBlock Grid.Row="3"
                                                       Grid.Column="1"
                                                       Text="{Binding WmComPort}"
                                                       Foreground="#E8E8F0"
                                                       Margin="0,0,0,6"
                                                       FontFamily="Consolas" />
                                            <TextBlock Grid.Row="4"
                                                       Text="{DynamicResource Settings_WmBaud}"
                                                       Foreground="#9898B0"
                                                       Margin="0,0,0,6" />
                                            <TextBlock Grid.Row="4"
                                                       Grid.Column="1"
                                                       Text="{Binding WmComBaudRate}"
                                                       Foreground="#E8E8F0"
                                                       Margin="0,0,0,6"
                                                       FontFamily="Consolas" />
                                            <TextBlock Grid.Row="5"
                                                       Text="{DynamicResource Settings_WmTableCh}"
                                                       Foreground="#9898B0"
                                                       Margin="0,0,0,6" />
                                            <TextBlock Grid.Row="5"
                                                       Grid.Column="1"
                                                       Text="{Binding WmTableChannelCount}"
                                                       Foreground="#E8E8F0"
                                                       Margin="0,0,0,6"
                                                       FontFamily="Consolas" />
                                            <TextBlock Grid.Row="6"
                                                       Text="{DynamicResource Settings_WmQueryDev}"
                                                       Foreground="#9898B0"
                                                       Margin="0,0,0,6" />
                                            <TextBlock Grid.Row="6"
                                                       Grid.Column="1"
                                                       Text="{Binding WmQueryDeviceId}"
                                                       Foreground="#E8E8F0"
                                                       Margin="0,0,0,6"
                                                       FontFamily="Consolas" />
                                        </Grid>
                                        <TextBlock Text="{DynamicResource Settings_WmAlarmHint}"
                                                   Foreground="#9898B0"
                                                   Margin="0,14,0,4" />
                                        <TextBlock Text="{Binding WmAlarmDelta, StringFormat={}{0:F3}}"
                                                   Foreground="#7C4DFF"
                                                   FontFamily="Consolas"
                                                   Margin="0,0,0,10" />
                                        <TextBlock Text="{DynamicResource Settings_WmSpecHint}"
                                                   Foreground="#9898B0"
                                                   Margin="0,0,0,8" />
                                        <DataGrid ItemsSource="{Binding WmServiceChannelSpecs}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  Background="Transparent"
                                                  Foreground="#E8E8F0"
                                                  BorderThickness="0"
                                                  GridLinesVisibility="Horizontal"
                                                  HorizontalGridLinesBrush="#334466"
                                                  RowBackground="#23233D"
                                                  AlternatingRowBackground="#1B1B2F"
                                                  HeadersVisibility="Column"
                                                  CanUserResizeRows="False"
                                                  MaxHeight="280">
                                            <DataGrid.ColumnHeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background" Value="#1B1B2F" />
                                                    <Setter Property="Foreground" Value="#9898B0" />
                                                    <Setter Property="Padding" Value="10,8" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                    <Setter Property="BorderBrush" Value="#334466" />
                                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                                </Style>
                                            </DataGrid.ColumnHeaderStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="{DynamicResource Settings_Grid_Index}"
                                                                    Binding="{Binding ChannelIndex}"
                                                                    Width="56" />
                                                <DataGridTextColumn Header="{DynamicResource Settings_Grid_Name}"
                                                                    Binding="{Binding ChannelName}"
                                                                    Width="120" />
                                                <DataGridTextColumn Header="{DynamicResource Settings_Grid_NomWl}"
                                                                    Binding="{Binding SpecWavelengthNm, StringFormat='{}{0:F3}'}"
                                                                    Width="110" />
                                                <DataGridTextColumn Header="{DynamicResource Settings_Grid_AlarmDeltaNm}"
                                                                    Binding="{Binding AlarmDeltaNm, StringFormat='{}{0:F3}'}"
                                                                    Width="90" />
                                                <DataGridCheckBoxColumn Header="{DynamicResource Settings_Grid_Enabled}"
                                                                        Binding="{Binding IsEnabled}"
                                                                        Width="56" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </Expander>
                            <Expander Header="{DynamicResource Settings_WbaSection}"
                                      IsExpanded="False"
                                      Foreground="#E8E8F0"
                                      Background="Transparent">
                                <Border Background="#1B1B2F"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding WbaDevicesSummary}"
                                                   Foreground="#9898B0"
                                                   Margin="0,0,0,12" />
                                        <DataGrid ItemsSource="{Binding WbaDevices}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  Background="Transparent"
                                                  Foreground="#E8E8F0"
                                                  BorderThickness="0"
                                                  GridLinesVisibility="Horizontal"
                                                  HorizontalGridLinesBrush="#334466"
                                                  RowBackground="#23233D"
                                                  AlternatingRowBackground="#1B1B2F"
                                                  HeadersVisibility="Column"
                                                  CanUserResizeRows="False"
                                                  MaxHeight="220">
                                            <DataGrid.ColumnHeaderStyle>
                                                <Style TargetType="DataGridColumnHeader">
                                                    <Setter Property="Background"
                                                            Value="#1B1B2F" />
                                                    <Setter Property="Foreground"
                                                            Value="#9898B0" />
                                                    <Setter Property="Padding"
                                                            Value="10,8" />
                                                    <Setter Property="FontWeight"
                                                            Value="SemiBold" />
                                                    <Setter Property="BorderBrush"
                                                            Value="#334466" />
                                                    <Setter Property="BorderThickness"
                                                            Value="0,0,0,1" />
                                                </Style>
                                            </DataGrid.ColumnHeaderStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="{DynamicResource Settings_Grid_DevSn}"
                                                                    Binding="{Binding DeviceSN}"
                                                                    Width="*">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontFamily"
                                                                    Value="Consolas" />
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="{DynamicResource Settings_Grid_Com}"
                                                                    Binding="{Binding ComPort}"
                                                                    Width="130">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontFamily"
                                                                    Value="Consolas" />
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridCheckBoxColumn Header="{DynamicResource Settings_Grid_Enabled}"
                                                                        Binding="{Binding Enabled}"
                                                                        Width="70" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- 通用设置：采集 / 邮件 / TMS -->
            <TabItem Header="{DynamicResource Settings_Tab_General}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Background="#23233D" CornerRadius="8" Padding="14" Margin="0,12,0,0">
                        <StackPanel Margin="0,10,0,0">
                            <Expander Header="{DynamicResource Settings_Language_Section}"
                                      IsExpanded="True"
                                      Foreground="#E8E8F0"
                                      Background="Transparent">
                                <Border Background="#1B1B2F"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,8,0,8">
                                    <StackPanel MaxWidth="720" HorizontalAlignment="Left">
                                        <TextBlock Text="{DynamicResource Settings_Language_Hint}"
                                                   Foreground="#9898B0"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,14" />
                                        <WrapPanel Margin="0,0,0,12">
                                            <RadioButton Margin="0,0,20,8"
                                                         GroupName="UiLang"
                                                         Foreground="#E8E8F0"
                                                         Content="{DynamicResource Language_zh_CN}"
                                                         IsChecked="{Binding SelectedLanguage, Converter={StaticResource StringMatchConverter}, ConverterParameter='zh-CN', Mode=TwoWay}" />
                                            <RadioButton Margin="0,0,20,8"
                                                         GroupName="UiLang"
                                                         Foreground="#E8E8F0"
                                                         Content="{DynamicResource Language_en_US}"
                                                         IsChecked="{Binding SelectedLanguage, Converter={StaticResource StringMatchConverter}, ConverterParameter='en-US', Mode=TwoWay}" />
                                            <RadioButton Margin="0,0,20,8"
                                                         GroupName="UiLang"
                                                         Foreground="#E8E8F0"
                                                         Content="{DynamicResource Language_ja_JP}"
                                                         IsChecked="{Binding SelectedLanguage, Converter={StaticResource StringMatchConverter}, ConverterParameter='ja-JP', Mode=TwoWay}" />
                                            <RadioButton Margin="0,0,20,8"
                                                         GroupName="UiLang"
                                                         Foreground="#E8E8F0"
                                                         Content="{DynamicResource Language_ms_MY}"
                                                         IsChecked="{Binding SelectedLanguage, Converter={StaticResource StringMatchConverter}, ConverterParameter='ms-MY', Mode=TwoWay}" />
                                            <RadioButton Margin="0,0,20,8"
                                                         GroupName="UiLang"
                                                         Foreground="#E8E8F0"
                                                         Content="{DynamicResource Language_vi_VN}"
                                                         IsChecked="{Binding SelectedLanguage, Converter={StaticResource StringMatchConverter}, ConverterParameter='vi-VN', Mode=TwoWay}" />
                                        </WrapPanel>
                                        <Button Content="{DynamicResource Settings_Language_Apply}"
                                                Command="{Binding ApplyUiLanguageCommand}"
                                                Style="{StaticResource ButtonPrimary}"
                                                HorizontalAlignment="Left"
                                                Padding="16,6" />
                                    </StackPanel>
                                </Border>
                            </Expander>
                            <Expander Header="{DynamicResource Settings_AcqSection}"
                                      IsExpanded="True"
                                      Foreground="#E8E8F0"
                                      Background="Transparent">
                                <Border Background="#1B1B2F"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,8,0,8">
                                    <StackPanel MaxWidth="720" HorizontalAlignment="Left">
                                        <TextBlock Text="{DynamicResource Settings_AcqIntro}"
                                                   Foreground="#9898B0"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,14" />
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="380" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="{DynamicResource Settings_AcqInterval}" Foreground="#E8E8F0" FontWeight="SemiBold" />
                                                <TextBlock Text="{DynamicResource Settings_AcqIntervalHint}" Foreground="#55556A" FontSize="11" />
                                            </StackPanel>
                                            <hc:NumericUpDown Grid.Column="1"
                                                                Value="{Binding SamplingIntervalMs}"
                                                                Minimum="2000"
                                                                Maximum="60000"
                                                                Increment="1000"
                                                                Width="180"
                                                                HorizontalAlignment="Left"
                                                                Style="{StaticResource NumericUpDownExtend}"
                                                                Margin="10,0,0,12" />

                                            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                                <TextBlock Text="{DynamicResource Settings_AcqWmEvery}" Foreground="#E8E8F0" FontWeight="SemiBold" />
                                                <TextBlock Text="{DynamicResource Settings_AcqWmEveryHint}" Foreground="#55556A" FontSize="11" />
                                            </StackPanel>
                                            <hc:NumericUpDown Grid.Row="1"
                                                                Grid.Column="1"
                                                                Value="{Binding WmSweepEveryN}"
                                                                Minimum="1"
                                                                Maximum="1000"
                                                                Increment="1"
                                                                Width="180"
                                                                HorizontalAlignment="Left"
                                                                Style="{StaticResource NumericUpDownExtend}"
                                                                Margin="10,0,0,12" />

                                            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                                                <TextBlock Text="{DynamicResource Settings_AcqWbaEvery}" Foreground="#E8E8F0" FontWeight="SemiBold" />
                                                <TextBlock Text="{DynamicResource Settings_AcqWbaEveryHint}" Foreground="#55556A" FontSize="11" />
                                            </StackPanel>
                                            <hc:NumericUpDown Grid.Row="2"
                                                                Grid.Column="1"
                                                                Value="{Binding WbaSweepEveryN}"
                                                                Minimum="1"
                                                                Maximum="1000"
                                                                Increment="1"
                                                                Width="180"
                                                                HorizontalAlignment="Left"
                                                                Style="{StaticResource NumericUpDownExtend}"
                                                                Margin="10,0,0,12" />

                                            <StackPanel Grid.Row="3" Margin="0,0,0,12">
                                                <TextBlock Text="{DynamicResource Settings_AcqDbEvery}" Foreground="#E8E8F0" FontWeight="SemiBold" />
                                                <TextBlock Text="{DynamicResource Settings_AcqDbEveryHint}" Foreground="#55556A" FontSize="11" />
                                            </StackPanel>
                                            <hc:NumericUpDown Grid.Row="3"
                                                                Grid.Column="1"
                                                                Value="{Binding DbWriteEveryN}"
                                                                Minimum="1"
                                                                Maximum="100"
                                                                Increment="1"
                                                                Width="180"
                                                                HorizontalAlignment="Left"
                                                                Style="{StaticResource NumericUpDownExtend}"
                                                                Margin="10,0,0,12" />
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Button Content="{DynamicResource Settings_AcqApply}"
                                                    Command="{Binding ApplyAcquisitionParamsCommand}"
                                                    Style="{StaticResource ButtonPrimary}"
                                                    HorizontalAlignment="Left"
                                                    Padding="16,6" />
                                            <TextBlock Text="{Binding AcqParamsStatus}"
                                                       Foreground="#00E676"
                                                       VerticalAlignment="Center"
                                                       Margin="16,0,0,0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <Expander Header="{DynamicResource Settings_EmailSection}"
                                      IsExpanded="False"
                                      Foreground="#E8E8F0"
                                      Background="Transparent">
                                <Border Background="#1B1B2F"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,8,0,8">
                                    <StackPanel MaxWidth="720" HorizontalAlignment="Left">
                                        <TextBlock Text="{DynamicResource Settings_EmailIntro}"
                                                   Foreground="#9898B0"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,14" />
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="{DynamicResource Settings_ApiUrl}" Foreground="#9898B0" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding EmailApiUrl}"
                                                     hc:InfoElement.Placeholder="http://zh-tms-srv1.oplink.com.cn:8800/api/email"
                                                     Style="{StaticResource TextBoxExtend}"
                                                     Margin="0,0,0,8" />

                                            <TextBlock Grid.Row="1"
                                                       Text="{DynamicResource Settings_EmailTo}"
                                                       Foreground="#9898B0"
                                                       VerticalAlignment="Top"
                                                       Margin="0,8,0,0" />
                                            <TextBox Grid.Row="1"
                                                     Grid.Column="1"
                                                     Text="{Binding Recipients}"
                                                     hc:InfoElement.Placeholder="{DynamicResource Settings_EmailRecipientsPlaceholder}"
                                                     Style="{StaticResource TextBoxExtend}"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     VerticalScrollBarVisibility="Auto"
                                                     MinHeight="88"
                                                     VerticalContentAlignment="Top"
                                                     Margin="0,0,0,8" />
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                            <Button Content="{DynamicResource Settings_EmailSave}"
                                                    Command="{Binding SaveEmailSettingsCommand}"
                                                    Style="{StaticResource ButtonPrimary}"
                                                    Background="#334466"
                                                    BorderBrush="#448AFF"
                                                    HorizontalAlignment="Left"
                                                    Padding="16,6"
                                                    Margin="0,0,8,0" />
                                            <Button Content="{DynamicResource Settings_EmailTest}"
                                                    Command="{Binding TestEmailApiCommand}"
                                                    Style="{StaticResource ButtonPrimary}"
                                                    HorizontalAlignment="Left"
                                                    Padding="16,6" />
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="12,0,0,0">
                                                <TextBlock Text="{Binding EmailTestStatusIcon}"
                                                           Foreground="{Binding EmailTestStatusColor}"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding EmailTestStatusText}"
                                                           Foreground="{Binding EmailTestStatusColor}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <Expander Header="{DynamicResource Settings_TmsSection}"
                                      IsExpanded="False"
                                      Foreground="#E8E8F0"
                                      Background="Transparent">
                                <Border Background="#1B1B2F"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,8,0,8">
                                    <StackPanel MaxWidth="720" HorizontalAlignment="Left">
                                        <TextBlock Text="{DynamicResource Settings_TmsIntro}"
                                                   Foreground="#9898B0"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,14" />
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="{DynamicResource Settings_ApiUrl}" Foreground="#9898B0" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding TmsBaseUrl}"
                                                     hc:InfoElement.Placeholder="https://tms.example.com/api"
                                                     Style="{StaticResource TextBoxExtend}"
                                                     Margin="0,0,0,8" />

                                            <TextBlock Grid.Row="1" Text="API Key:" Foreground="#9898B0" VerticalAlignment="Center" />
                                            <TextBox Grid.Row="1"
                                                     Grid.Column="1"
                                                     Text="{Binding TmsApiKey}"
                                                     Style="{StaticResource TextBoxExtend}"
                                                     Margin="0,0,0,8" />

                                            <TextBlock Grid.Row="2" Text="{DynamicResource Settings_TmsUploadSec}" Foreground="#9898B0" VerticalAlignment="Center" />
                                            <hc:NumericUpDown Grid.Row="2"
                                                              Grid.Column="1"
                                                              Value="{Binding TmsUploadIntervalSec}"
                                                              Minimum="10"
                                                              Maximum="3600"
                                                              Width="180"
                                                              HorizontalAlignment="Left"
                                                              Style="{StaticResource NumericUpDownExtend}" />
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                            <Button Content="{DynamicResource Settings_TmsSave}"
                                                    Command="{Binding SaveTmsSettingsCommand}"
                                                    Style="{StaticResource ButtonPrimary}"
                                                    Background="#334466"
                                                    BorderBrush="#448AFF"
                                                    HorizontalAlignment="Left"
                                                    Padding="16,6"
                                                    Margin="0,0,8,0" />
                                            <Button Content="{DynamicResource Settings_TmsTest}"
                                                    Command="{Binding TestTmsConnectionCommand}"
                                                    Style="{StaticResource ButtonPrimary}"
                                                    HorizontalAlignment="Left"
                                                    Padding="16,6" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </ScrollViewer>
</UserControl>
