<UserControl x:Class="LightSourceMonitor.Views.AlarmPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filter Bar -->
        <Border Background="#23233D" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="筛选:" Foreground="#9898B0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding LevelOptions}" SelectedItem="{Binding SelectedLevel}"
                          Width="100" Margin="0,0,12,0" Style="{StaticResource ComboBoxExtend}"/>
                <ComboBox ItemsSource="{Binding TimeRangeOptions}" SelectedItem="{Binding SelectedTimeRange}"
                          Width="140" Margin="0,0,12,0" Style="{StaticResource ComboBoxExtend}"/>
                <hc:SearchBar Width="200" SearchStarted="SearchBar_OnSearchStarted"
                              hc:InfoElement.Placeholder="搜索通道..."
                              Style="{StaticResource SearchBarExtend}" Margin="0,0,12,0"/>
                <Button Command="{Binding RefreshCommand}" Margin="0,0,12,0" Padding="8,4"
                        Style="{StaticResource ButtonPrimary}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄" Margin="0,0,4,0"/>
                        <TextBlock Text="刷新"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding TotalAlarmCount, StringFormat='共 {0} 条'}" Foreground="#9898B0"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <ToggleButton IsChecked="{Binding IsMuted}" Margin="0,0,0,0" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔇" Margin="0,0,4,0"/>
                        <TextBlock Text="静音" Foreground="#E8E8F0"/>
                    </StackPanel>
                </ToggleButton>
            </WrapPanel>
        </Border>

        <!-- Alarm DataGrid -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Alarms}" AutoGenerateColumns="False"
                  IsReadOnly="True" Background="#23233D" Foreground="#E8E8F0"
                  BorderThickness="0" GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#334466"
                  RowBackground="#23233D" AlternatingRowBackground="#1B1B2F"
                  HeadersVisibility="Column" CanUserResizeRows="False"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1B1B2F"/>
                    <Setter Property="Foreground" Value="#9898B0"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderBrush" Value="#334466"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="32">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="10" Height="10" HorizontalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{Binding LevelColor}"/>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="时间" Binding="{Binding OccurredAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="Foreground" Value="#E8E8F0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="级别" Binding="{Binding Level}" Width="60"/>
                <DataGridTextColumn Header="通道" Binding="{Binding ChannelName}" Width="220"/>
                <DataGridTextColumn Header="测量值" Binding="{Binding MeasuredValue, StringFormat='{}{0:F3}'}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="Foreground" Value="#E8E8F0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Spec值" Binding="{Binding SpecValue, StringFormat='{}{0:F3}'}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="Foreground" Value="#9898B0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="偏差Δ" Binding="{Binding Delta, StringFormat='{}{0:F3}'}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="Foreground" Value="#FF1744"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="邮件" Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="-"/>
                                        <Setter Property="Foreground" Value="#55556A"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EmailSent}" Value="True">
                                                <Setter Property="Text" Value="✓"/>
                                                <Setter Property="Foreground" Value="#00E676"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
