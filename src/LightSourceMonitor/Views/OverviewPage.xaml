<UserControl x:Class="LightSourceMonitor.Views.OverviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:vm="clr-namespace:LightSourceMonitor.ViewModels">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <!-- KPI Summary Cards -->
            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,16">
                <!-- Total Channels -->
                <Border Background="#23233D" CornerRadius="8" Margin="0,0,8,0" Padding="16">
                    <StackPanel>
                        <TextBlock Text="激光器总数" Foreground="#9898B0"/>
                        <TextBlock Text="{Binding TotalChannels}" Style="{StaticResource KpiValueText}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <!-- Normal -->
                <Border Background="#23233D" CornerRadius="8" Margin="4,0" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#00E676" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="正常通道" Foreground="#9898B0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding NormalCount}" Foreground="#00E676"
                                   FontFamily="Consolas" FontSize="40" FontWeight="Bold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <!-- Warning -->
                <Border Background="#23233D" CornerRadius="8" Margin="4,0" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#FF1744" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="告警通道" Foreground="#9898B0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding WarningCount}" Foreground="#FF1744"
                                   FontFamily="Consolas" FontSize="40" FontWeight="Bold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <!-- Offline -->
                <Border Background="#23233D" CornerRadius="8" Margin="8,0,0,0" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#616161" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="离线通道" Foreground="#9898B0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding OfflineCount}" Foreground="#616161"
                                   FontFamily="Consolas" FontSize="40" FontWeight="Bold" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Device Groups -->
            <ItemsControl ItemsSource="{Binding DeviceGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:DeviceGroupViewModel}">
                        <Border Background="#23233D" CornerRadius="8" Margin="0,0,0,12" Padding="16">
                            <StackPanel>
                                <!-- Device Header -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#616161"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                        <Setter Property="Fill" Value="#00E676"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding DeviceName}" FontSize="17" FontWeight="SemiBold" 
                                               Foreground="#E8E8F0" VerticalAlignment="Center"/>
                                    <TextBlock Text=" (SN: " Foreground="#9898B0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding DeviceSn}" Foreground="#9898B0" FontFamily="Consolas"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text=")" Foreground="#9898B0" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Channel Cards Grid -->
                                <ItemsControl ItemsSource="{Binding Channels}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ChannelCardViewModel}">
                                            <Border Width="160" Margin="0,0,8,8" Padding="12"
                                                    CornerRadius="6" Cursor="Hand"
                                                    BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1B1B2F"/>
                                                        <Setter Property="BorderBrush" Value="#334466"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StatusColor}" Value="#FF1744">
                                                                <Setter Property="BorderBrush" Value="#FF1744"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusColor}" Value="#FFAB00">
                                                                <Setter Property="BorderBrush" Value="#FFAB00"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.ToolTip>
                                                    <StackPanel Margin="4">
                                                        <TextBlock FontWeight="SemiBold" Margin="0,0,0,4">
                                                            <Run Text="{Binding ChannelName, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding SpecValue, StringFormat='Spec: {0:F3}'}"/>
                                                        <TextBlock Text="{Binding MaxValue, StringFormat='Max: {0:F3}'}"/>
                                                        <TextBlock Text="{Binding MinValue, StringFormat='Min: {0:F3}'}"/>
                                                        <TextBlock Text="{Binding Delta, StringFormat='Delta: {0:F3}'}"/>
                                                        <TextBlock Text="{Binding LastUpdate, StringFormat='更新: {0}'}"/>
                                                    </StackPanel>
                                                </Border.ToolTip>
                                                <StackPanel>
                                                    <!-- Channel name + status dot -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                        <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                                                 VerticalAlignment="Center">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="{Binding StatusColor}"/>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <TextBlock Text="{Binding ChannelName}" Foreground="#9898B0"
                                                                   FontSize="13"/>
                                                    </StackPanel>
                                                    <!-- Current value -->
                                                    <TextBlock Text="{Binding CurrentValue, StringFormat='{}{0:F2}'}"
                                                               FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                                                               Foreground="#E8E8F0"/>
                                                    <TextBlock Text="{Binding Unit}" Foreground="#55556A" FontSize="13"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Recent Alarms Bar -->
            <Border Background="#23233D" CornerRadius="8" Padding="16" Margin="0,4,0,0">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="最新告警" FontSize="17" FontWeight="SemiBold" Foreground="#E8E8F0"/>
                        <TextBlock Text="查看全部 >" Foreground="#448AFF" Cursor="Hand"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding RecentAlarms}" MaxHeight="120">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AlarmItemViewModel}">
                                <Border Margin="0,0,0,4" Padding="8,6" CornerRadius="4" Background="#1B1B2F">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="3" CornerRadius="2" Margin="0,0,8,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{Binding LevelColor}"/>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" 
                                                   Foreground="#9898B0" FontFamily="Consolas"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding ChannelName}" Foreground="#E8E8F0" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Message}" Foreground="#9898B0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="暂无告警" Foreground="#55556A" HorizontalAlignment="Center"
                               Margin="0,8,0,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentAlarms.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
