<UserControl x:Class="LightSourceMonitor.Views.OverviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:vm="clr-namespace:LightSourceMonitor.ViewModels">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- KPI Summary Cards -->
        <UniformGrid Grid.Row="0" Rows="1" Columns="4" Margin="0,0,0,16">
            <Border Background="#23233D" CornerRadius="8" Margin="0,0,8,0" Padding="16">
                <StackPanel>
                    <TextBlock Text="激光器总数" Foreground="#9898B0"/>
                    <TextBlock Text="{Binding TotalChannels}" Style="{StaticResource KpiValueText}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#23233D" CornerRadius="8" Margin="4,0" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#00E676" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="正常通道" Foreground="#9898B0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding NormalCount}" Foreground="#00E676"
                               FontFamily="Consolas" FontSize="40" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#23233D" CornerRadius="8" Margin="4,0" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#FF1744" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="告警通道" Foreground="#9898B0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding WarningCount}" Foreground="#FF1744"
                               FontFamily="Consolas" FontSize="40" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#23233D" CornerRadius="8" Margin="8,0,0,0" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#616161" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="离线通道" Foreground="#9898B0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding OfflineCount}" Foreground="#616161"
                               FontFamily="Consolas" FontSize="40" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Device Container List -->
        <Border Grid.Row="1" Background="#23233D" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="4,2,4,10">
                    <TextBlock Text="PD 设备列表" FontSize="16" FontWeight="SemiBold" Foreground="#E8E8F0"/>
                    <Border Background="#1B1B2F" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right">
                        <TextBlock Foreground="#9898B0" FontFamily="Consolas"
                                   Text="{Binding DeviceGroups.Count, StringFormat=设备数: {0}}"/>
                    </Border>
                </DockPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding DeviceGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:DeviceGroupViewModel}">
                                <Border CornerRadius="8" Margin="0,0,0,10" Padding="8" Background="#1B1B2F">
                                    <Expander IsExpanded="True" Background="Transparent" BorderThickness="0">
                                        <Expander.Header>
                                            <DockPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#616161"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                        <Setter Property="Fill" Value="#00E676"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding DeviceName}" FontSize="16" FontWeight="SemiBold" Foreground="#E8E8F0"/>
                                                    <TextBlock Text=" (SN: " Foreground="#9898B0"/>
                                                    <TextBlock Text="{Binding DeviceSn}" Foreground="#9898B0" FontFamily="Consolas"/>
                                                    <TextBlock Text=")" Foreground="#9898B0"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <TextBlock Margin="0,0,12,0" Foreground="#9898B0" FontFamily="Consolas"
                                                               Text="{Binding Channels.Count, StringFormat=通道: {0}}"/>
                                                    <TextBlock Foreground="#9898B0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="离线"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                        <Setter Property="Text" Value="在线"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DockPanel>
                                        </Expander.Header>

                                        <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,10,0,0">
                                            <ItemsControl ItemsSource="{Binding Channels}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:ChannelCardViewModel}">
                                                        <Border Width="158" Margin="0,0,8,8" Padding="12"
                                                                CornerRadius="6" Cursor="Hand" BorderThickness="1">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#23233D"/>
                                                                    <Setter Property="BorderBrush" Value="#334466"/>
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                                            <Setter Property="Opacity" Value="0.45"/>
                                                                            <Setter Property="BorderBrush" Value="#444455"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding StatusColor}" Value="#FF1744">
                                                                            <Setter Property="BorderBrush" Value="#FF1744"/>
                                                                            <Setter Property="BorderThickness" Value="2"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding StatusColor}" Value="#FFAB00">
                                                                            <Setter Property="BorderBrush" Value="#FFAB00"/>
                                                                            <Setter Property="BorderThickness" Value="2"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Border.ToolTip>
                                                                <StackPanel Margin="4">
                                                                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,4">
                                                                        <Run Text="{Binding ChannelName, Mode=OneWay}"/>
                                                                    </TextBlock>
                                                                    <TextBlock Text="{Binding SpecValue, StringFormat='Spec: {0:F3}'}"/>
                                                                    <TextBlock Text="{Binding MaxValue, StringFormat='Max: {0:F3}'}"/>
                                                                    <TextBlock Text="{Binding MinValue, StringFormat='Min: {0:F3}'}"/>
                                                                    <TextBlock Text="{Binding Delta, StringFormat='Delta: {0:F3}'}"/>
                                                                    <TextBlock Text="{Binding LastUpdate, StringFormat='更新: {0}'}"/>
                                                                </StackPanel>
                                                            </Border.ToolTip>
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                             Fill="{Binding StatusColor}"/>
                                                                    <TextBlock Text="{Binding ChannelName}" Foreground="#9898B0" FontSize="13"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding DisplayValue}" FontFamily="Consolas" FontSize="22" FontWeight="Bold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="#E8E8F0"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                                                    <Setter Property="Foreground" Value="#55556A"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding Unit}" Foreground="#55556A" FontSize="13" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Expander>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Recent Alarms Bar -->
        <Border Grid.Row="2" Background="#23233D" CornerRadius="8" Padding="16" Margin="0,0,0,0">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="最新告警" FontSize="17" FontWeight="SemiBold" Foreground="#E8E8F0"/>
                    <Button Command="{Binding NavigateToAlarmsCommand}"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0">
                        <TextBlock Text="查看全部 >" Foreground="#448AFF" FontWeight="SemiBold"/>
                    </Button>
                </DockPanel>
                <ItemsControl ItemsSource="{Binding RecentAlarms}" MaxHeight="120">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:AlarmItemViewModel}">
                            <Border Margin="0,0,0,4" Padding="8,6" CornerRadius="4" Background="#1B1B2F">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="3" CornerRadius="2" Margin="0,0,8,0" Background="{Binding LevelColor}"/>
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                               Foreground="#9898B0" FontFamily="Consolas"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding ChannelName}" Foreground="#E8E8F0" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Message}" Foreground="#9898B0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="暂无告警" Foreground="#55556A" HorizontalAlignment="Center" Margin="0,8,0,8">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RecentAlarms.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
