<UserControl x:Class="LightSourceMonitor.Views.OverviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:vm="clr-namespace:LightSourceMonitor.ViewModels">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Device Containers: PD | Wavelength table | WBA -->
        <Grid Grid.Row="0" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="235"/>
            </Grid.ColumnDefinitions>

            <!-- PD Device List -->
            <Border Grid.Column="0" Background="#23233D" CornerRadius="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="4,2,4,10">
                        <TextBlock Text="PD 设备列表" FontSize="16" FontWeight="SemiBold" Foreground="#E8E8F0"/>
                        <Border Background="#1B1B2F" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right">
                            <TextBlock Foreground="#9898B0" FontFamily="Consolas"
                                       Text="{Binding DeviceGroups.Count, StringFormat=设备数: {0}}"/>
                        </Border>
                    </DockPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding DeviceGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DeviceGroupViewModel}">
                                    <Border CornerRadius="8" Margin="0,0,0,10" Padding="8" Background="#1B1B2F">
                                        <Expander IsExpanded="True" Background="Transparent" BorderThickness="0">
                                            <Expander.Header>
                                                <DockPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="#616161"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                            <Setter Property="Fill" Value="#00E676"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <TextBlock Text="{Binding DeviceName}" FontSize="16" FontWeight="SemiBold" Foreground="#E8E8F0"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <TextBlock Margin="0,0,12,0" Foreground="#9898B0" FontFamily="Consolas"
                                                                   Text="{Binding Channels.Count, StringFormat=通道: {0}}"/>
                                                        <TextBlock Foreground="#9898B0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="离线"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                            <Setter Property="Text" Value="在线"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Expander.Header>

                                            <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,10,0,0">
                                                <ItemsControl ItemsSource="{Binding Channels}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:ChannelCardViewModel}">
                                                            <Border Width="158" Margin="0,0,8,8" Padding="8"
                                                                    CornerRadius="6" Cursor="Hand" BorderThickness="1">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#23233D"/>
                                                                        <Setter Property="BorderBrush" Value="#334466"/>
                                                                        <Setter Property="Opacity" Value="1"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                                                <Setter Property="Opacity" Value="0.45"/>
                                                                                <Setter Property="BorderBrush" Value="#444455"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding StatusColor}" Value="#FF1744">
                                                                                <Setter Property="BorderBrush" Value="#FF1744"/>
                                                                                <Setter Property="BorderThickness" Value="2"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding StatusColor}" Value="#FFAB00">
                                                                                <Setter Property="BorderBrush" Value="#FFAB00"/>
                                                                                <Setter Property="BorderThickness" Value="2"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <Border.ToolTip>
                                                                    <StackPanel Margin="4">
                                                                        <TextBlock FontWeight="SemiBold" Margin="0,0,0,4">
                                                                            <Run Text="{Binding ChannelName, Mode=OneWay}"/>
                                                                        </TextBlock>
                                                                        <TextBlock Text="{Binding SpecValue, StringFormat='Spec: {0:F3}'}"/>
                                                                        <TextBlock Text="{Binding MaxValue, StringFormat='Max: {0:F3}'}"/>
                                                                        <TextBlock Text="{Binding MinValue, StringFormat='Min: {0:F3}'}"/>
                                                                        <TextBlock Text="{Binding Delta, StringFormat='Delta: {0:F3}'}"/>
                                                                        <TextBlock Text="{Binding LastUpdate, StringFormat='更新: {0}'}"/>
                                                                    </StackPanel>
                                                                </Border.ToolTip>
                                                                <StackPanel>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                                        <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                                 Fill="{Binding StatusColor}"/>
                                                                        <TextBlock Text="{Binding ChannelName}" Foreground="#9898B0" FontSize="13"/>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding DisplayValue}" FontFamily="Consolas" FontSize="22" FontWeight="Bold">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Foreground" Value="#E8E8F0"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                                                        <Setter Property="Foreground" Value="#55556A"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <TextBlock Text="{Binding Unit}" Foreground="#55556A" FontSize="13" Margin="0,2,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Expander>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Wavelength meter (multi-channel table) -->
            <Border Grid.Column="2" Background="#23233D" CornerRadius="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="4,2,4,10">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="波长计（多路）" FontSize="16" FontWeight="SemiBold" Foreground="#E8E8F0"/>
                            <TextBlock Text="{Binding WavelengthTableSubtitle}" Foreground="#9898B0" FontSize="11" FontFamily="Consolas" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Background="#1B1B2F" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <TextBlock Foreground="#9898B0" FontFamily="Consolas"
                                       Text="{Binding WavelengthRows.Count, StringFormat=路数: {0}}"/>
                        </Border>
                    </DockPanel>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding WavelengthRows}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Background="#1B1B2F"
                              Foreground="#E8E8F0"
                              BorderThickness="0"
                              RowBackground="#23233D"
                              AlternatingRowBackground="#1B1B2F"
                              HorizontalGridLinesBrush="#2A2A3E"
                              VerticalGridLinesBrush="#2A2A3E"
                              ColumnHeaderHeight="32">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#1B1B2F"/>
                                <Setter Property="Foreground" Value="#9898B0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderBrush" Value="#2A2A3E"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="Foreground" Value="#E8E8F0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="序号" Binding="{Binding ChannelIndex}" Width="56"/>
                            <DataGridTextColumn Header="波长 nm" Binding="{Binding WavelengthDisplay}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="Consolas" />
                                        <Setter Property="FontSize" Value="13" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="Foreground" Value="{Binding WavelengthForeground}" />
                                        <Setter Property="ToolTip" Value="{Binding WavelengthToolTip}" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="更新时间" Binding="{Binding LastUpdate}" Width="88"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- WBA Device List -->
            <Border Grid.Column="4" Background="#23233D" CornerRadius="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="4,2,4,10">
                        <TextBlock Text="WBA 设备列表" FontSize="16" FontWeight="SemiBold" Foreground="#E8E8F0"/>
                        <Border Background="#1B1B2F" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right">
                            <TextBlock Foreground="#9898B0" FontFamily="Consolas"
                                       Text="{Binding WbaDeviceGroups.Count, StringFormat=设备数: {0}}"/>
                        </Border>
                    </DockPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding WbaDeviceGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:WbaDeviceGroupViewModel}">
                                    <Border CornerRadius="8" Margin="0,0,0,10" Padding="10" Background="#1B1B2F" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#2A2A3E"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#1E4A3A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <!-- WBA Device Header -->
                                            <DockPanel Margin="0,0,0,10">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#616161"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                        <Setter Property="Fill" Value="#00E676"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding DeviceSn}" FontSize="14" FontWeight="SemiBold"
                                                               Foreground="#E8E8F0" FontFamily="Consolas"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding LastUpdate, StringFormat='更新: {0}'}"
                                                           Foreground="#55556A" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </DockPanel>

                                            <!-- No Data State -->
                                            <TextBlock Text="等待 WBA 数据..." Foreground="#55556A" FontSize="12"
                                                       HorizontalAlignment="Center" Margin="0,8,0,8">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasData}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Data Panel -->
                                            <StackPanel>
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasData}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>

                                                <!-- Temperatures -->
                                                <TextBlock Text="温度" Foreground="#9898B0" FontSize="11" Margin="0,0,0,4"/>
                                                <ItemsControl ItemsSource="{Binding Temperatures}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Rows="2" Columns="2"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:WbaMetricViewModel}">
                                                            <Border Margin="0,0,4,4" Padding="8,6" CornerRadius="4" Background="#23233D">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Name}" Foreground="#9898B0" FontSize="10"/>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                        <TextBlock Text="{Binding DisplayValue}" Foreground="#FF9800"
                                                                                   FontFamily="Consolas" FontSize="16" FontWeight="Bold"/>
                                                                        <TextBlock Text="{Binding Unit}" Foreground="#55556A" FontSize="10" Margin="2,4,0,0"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- Voltages -->
                                                <TextBlock Text="电压" Foreground="#9898B0" FontSize="11" Margin="0,8,0,4"/>
                                                <ItemsControl ItemsSource="{Binding Voltages}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Rows="2" Columns="2"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:WbaMetricViewModel}">
                                                            <Border Margin="0,0,4,4" Padding="8,6" CornerRadius="4" Background="#23233D">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Name}" Foreground="#9898B0" FontSize="10"/>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                        <TextBlock Text="{Binding DisplayValue}" Foreground="#448AFF"
                                                                                   FontFamily="Consolas" FontSize="16" FontWeight="Bold"/>
                                                                        <TextBlock Text="{Binding Unit}" Foreground="#55556A" FontSize="10" Margin="2,4,0,0"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- Pressure -->
                                                <TextBlock Text="气压" Foreground="#9898B0" FontSize="11" Margin="0,8,0,4"/>
                                                <Border Padding="8,6" CornerRadius="4" Background="#23233D">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding PressureDisplay}" Foreground="#00E5FF"
                                                                   FontFamily="Consolas" FontSize="16" FontWeight="Bold"/>
                                                        <TextBlock Text=" kPa" Foreground="#55556A" FontSize="10" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Recent Alarms Bar -->
        <Border Grid.Row="1" Background="#23233D" CornerRadius="8" Padding="16" Margin="0,0,0,0">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="最新告警" FontSize="17" FontWeight="SemiBold" Foreground="#E8E8F0"/>
                    <Button Command="{Binding NavigateToAlarmsCommand}"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0">
                        <TextBlock Text="查看全部 >" Foreground="#448AFF" FontWeight="SemiBold"/>
                    </Button>
                </DockPanel>
                <ItemsControl ItemsSource="{Binding RecentAlarms}" MaxHeight="120">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:AlarmItemViewModel}">
                            <Border Margin="0,0,0,4" Padding="8,6" CornerRadius="4" Background="#1B1B2F">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="3" CornerRadius="2" Margin="0,0,8,0" Background="{Binding LevelColor}"/>
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:MM-dd HH:mm:ss}'}"
                                               Foreground="#9898B0" FontFamily="Consolas"
                                               VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="110"/>
                                    <TextBlock Text="{Binding DeviceSn}" Foreground="#B0B0C8" FontFamily="Consolas"
                                               VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="100"/>
                                    <TextBlock Text="{Binding ChannelName}" Foreground="#E8E8F0" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="72"/>
                                    <TextBlock Text="{Binding Level}" Foreground="{Binding LevelColor}" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0" MinWidth="36"/>
                                    <TextBlock Text="{Binding Message}" Foreground="#9898B0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="暂无告警" Foreground="#55556A" HorizontalAlignment="Center" Margin="0,8,0,8">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RecentAlarms.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
