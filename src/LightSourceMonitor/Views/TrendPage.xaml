<UserControl x:Class="LightSourceMonitor.Views.TrendPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:vm="clr-namespace:LightSourceMonitor.ViewModels">
    <UserControl.Resources>
        <DataTemplate x:Key="TrendGroupChartTemplate" DataType="{x:Type vm:TrendChartGroupViewModel}">
            <Border Margin="0,0,0,16" Background="#1B1B2F" CornerRadius="8" Padding="12">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" Foreground="#E8E8F0" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <lvc:CartesianChart Height="280"
                                        Series="{Binding Series}"
                                        XAxes="{Binding XAxes}"
                                        YAxes="{Binding YAxes}"
                                        ZoomMode="X"
                                        TooltipPosition="Top"
                                        LegendPosition="Bottom"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Background="#23233D" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="时间范围:" Foreground="#9898B0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding TimeRangeOptions}" SelectedItem="{Binding SelectedTimeRange}"
                          Width="140" Margin="0,0,16,0" Style="{StaticResource ComboBoxExtend}"/>

                <Button Content="🔄 刷新" Command="{Binding LoadDataCommand}" Margin="0,0,8,0"
                        Style="{StaticResource ButtonPrimary}" Padding="12,4"/>
                <Button Content="导出 CSV" Command="{Binding ExportCsvCommand}" Margin="0,0,8,0"
                        Style="{StaticResource ButtonDefault}" Padding="12,4"/>
                <Button Content="导出 PNG" Click="ExportPng_Click"
                        Style="{StaticResource ButtonDefault}" Padding="12,4"/>
            </WrapPanel>
        </Border>

        <TabControl Grid.Row="1"
                    SelectedIndex="{Binding SelectedTrendSubTabIndex, Mode=TwoWay}"
                    Background="Transparent"
                    BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="#E8E8F0"/>
                    <Setter Property="Padding" Value="16,8"/>
                </Style>
            </TabControl.Resources>

            <TabItem Header="PD">
                <Border x:Name="PdChartHost" Background="#23233D" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                    <lvc:CartesianChart Series="{Binding Series}"
                                        XAxes="{Binding XAxes}"
                                        YAxes="{Binding YAxes}"
                                        ZoomMode="X"
                                        TooltipPosition="Top"
                                        LegendPosition="Bottom"/>
                </Border>
            </TabItem>

            <TabItem Header="WM">
                <Border x:Name="WmChartsHost" Background="#23233D" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <CheckBox Content="相对标称（偏差 nm）"
                                  IsChecked="{Binding WmShowDeviation, Mode=TwoWay}"
                                  Foreground="#E8E8F0"
                                  Margin="0,0,0,12"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemTemplate="{StaticResource TrendGroupChartTemplate}"
                                          ItemsSource="{Binding WmTrendGroups}"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="WBA">
                <Border x:Name="WbaChartsHost" Background="#23233D" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <WrapPanel VerticalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock Text="指标:" Foreground="#9898B0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding WbaMetricOptions}"
                                      SelectedIndex="{Binding WbaTrendMetricIndex, Mode=TwoWay}"
                                      Width="200"
                                      Style="{StaticResource ComboBoxExtend}"/>
                        </WrapPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemTemplate="{StaticResource TrendGroupChartTemplate}"
                                          ItemsSource="{Binding WbaTrendGroups}"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Margin="0,8,0,0">
            <DockPanel>
                <TextBlock Text="{Binding StatusText}" Foreground="#9898B0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding DataPointCount, StringFormat='数据点: {0}'}"
                           Foreground="#55556A" HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontFamily="Consolas"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
