<UserControl x:Class="LightSourceMonitor.Views.TrendPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Background="#23233D" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="时间范围:" Foreground="#9898B0" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding TimeRangeOptions}" SelectedItem="{Binding SelectedTimeRange}"
                          Width="140" Margin="0,0,16,0" Style="{StaticResource ComboBoxExtend}"/>

                <Button Content="🔄 刷新" Command="{Binding LoadDataCommand}" Margin="0,0,8,0"
                        Style="{StaticResource ButtonPrimary}" Padding="12,4"/>
                <Button Content="导出 CSV" Command="{Binding ExportCsvCommand}" Margin="0,0,8,0"
                        Style="{StaticResource ButtonDefault}" Padding="12,4"/>
                <Button Content="导出 PNG" Click="ExportPng_Click"
                        Style="{StaticResource ButtonDefault}" Padding="12,4"/>
            </WrapPanel>
        </Border>

        <!-- Chart -->
        <Grid Grid.Row="1">
            <Border x:Name="ChartContainer" Background="#23233D" CornerRadius="8" Padding="12">
                <lvc:CartesianChart Series="{Binding Series}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding YAxes}"
                                    ZoomMode="X"
                                    TooltipPosition="Top"
                                    LegendPosition="Right"
                                    LegendTextSize="10"/>
            </Border>
            <Border Panel.ZIndex="1"
                    Background="#D8151525"
                    Visibility="{Binding IsTrendDataLoading, Converter={StaticResource BoolToVisibility}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar Width="260" Height="4"
                                 IsIndeterminate="True"
                                 Foreground="#448AFF"
                                 Background="#2D2D4A"
                                 BorderThickness="0"/>
                    <TextBlock Text="正在加载趋势数据…"
                               Foreground="#E8E8F0"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,14,0,0"/>
                    <TextBlock Text="数据量大时可能需要数秒"
                               Foreground="#9898B0"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Margin="0,8,0,0">
            <DockPanel>
                <TextBlock Text="{Binding StatusText}" Foreground="#9898B0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding DataPointCount, StringFormat='数据点: {0}'}" 
                           Foreground="#55556A" HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontFamily="Consolas"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
