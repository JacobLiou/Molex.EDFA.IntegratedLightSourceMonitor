<UserControl x:Class="LightSourceMonitor.Views.TrendHostPage"
             x:Name="RootHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:LightSourceMonitor.Views">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 自定义“Tab”头：不用 TabControl，避免非当前页 Unloaded 触发 LiveCharts Dispose NRE -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="BtnPd" Content="PD 功率" Margin="0,0,8,0" Padding="14,6"
                    Click="PdTrendTab_Click"
                    Foreground="#E8E8F0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ButtonDefault}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.ActiveTrendTab, ElementName=RootHost}" Value="0">
                                <Setter Property="Background" Value="#2D2D4A"/>
                                <Setter Property="Foreground" Value="#448AFF"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button x:Name="BtnWm" Content="波长计" Padding="14,6"
                    Click="WmTrendTab_Click"
                    Foreground="#E8E8F0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ButtonDefault}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.ActiveTrendTab, ElementName=RootHost}" Value="1">
                                <Setter Property="Background" Value="#2D2D4A"/>
                                <Setter Property="Foreground" Value="#448AFF"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Visibility 必须相对宿主 VM：子页 DataContext 已是 PdTrend/WmTrend，不能在同一元素上绑 IsPdTrendTabActive -->
        <Grid Grid.Row="1">
            <Grid>
                <views:TrendPage DataContext="{Binding PdTrend}"
                                 Margin="0,0,0,0"
                                 Visibility="{Binding DataContext.IsPdTrendTabActive, ElementName=RootHost, Converter={StaticResource BoolToVisibility}}"/>
                <views:WmTrendPage DataContext="{Binding WmTrend}"
                                   Margin="0,0,0,0"
                                   Visibility="{Binding DataContext.IsWmTrendTabActive, ElementName=RootHost, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>

            <Border Panel.ZIndex="1"
                    Background="#D8151525"
                    Visibility="{Binding IsActiveTrendLoading, Converter={StaticResource BoolToVisibility}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar Width="260" Height="4"
                                 IsIndeterminate="True"
                                 Foreground="#448AFF"
                                 Background="#2D2D4A"
                                 BorderThickness="0"/>
                    <TextBlock Text="正在加载趋势数据…"
                               Foreground="#E8E8F0"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,14,0,0"/>
                    <TextBlock Text="数据量大时可能需要数秒"
                               Foreground="#9898B0"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
